"""Coordinator for calculations."""
from datetime import date, datetime, timedelta
import logging
from typing import Any, cast

from prayer_times_calculator_offline import PrayerTimesCalculator

from homeassistant.config_entries import ConfigEntry
from homeassistant.core import CALLBACK_TYPE, HomeAssistant, callback
from homeassistant.helpers.event import async_track_point_in_time, async_track_state_change_event
from homeassistant.helpers.update_coordinator import DataUpdateCoordinator
from homeassistant.util import dt as dt_util

from .const import (
    CONF_CALC_METHOD,
    CONF_LAT_ADJ_METHOD,
    CONF_METHOD_TYPE,
    CONF_MIDNIGHT_MODE,
    CONF_SCHOOL,
    CONF_TRACKING_ENTITY,
    DEFAULT_CALC_METHOD,
    DEFAULT_LAT_ADJ_METHOD,
    DEFAULT_MIDNIGHT_MODE,
    DEFAULT_SCHOOL,
    DOMAIN,
    METHOD_TRACKER,
)

_LOGGER = logging.getLogger(__name__)

class IslamicPrayerDataUpdateCoordinator(DataUpdateCoordinator):
    """Manage dynamic execution calculations."""

    def __init__(self, hass: HomeAssistant, config_entry: ConfigEntry) -> None:
        """Initialize tracking handles."""
        super().__init__(hass, _LOGGER, name=DOMAIN)
        self.config_entry = config_entry
        self.location_type = config_entry.data.get(CONF_METHOD_TYPE)
        self.tracking_entity = config_entry.data.get(CONF_TRACKING_ENTITY)
        
        self.latitude = hass.config.latitude
        self.longitude = hass.config.longitude
        self.event_unsub: CALLBACK_TYPE | None = None

        if self.location_type == METHOD_TRACKER and self.tracking_entity:
            async_track_state_change_event(
                hass, [self.tracking_entity], self._async_handle_location_change
            )

    async def _async_handle_location_change(self, event: Any) -> None:
        """Instantly recalculate if target moves."""
        await self.async_request_refresh()

    @property
    def calc_method(self) -> str:
        return self.config_entry.options.get(CONF_CALC_METHOD, DEFAULT_CALC_METHOD)

    @property
    def lat_adj_method(self) -> str:
        raw = str(self.config_entry.options.get(CONF_LAT_ADJ_METHOD, DEFAULT_LAT_ADJ_METHOD)).lower()
        if raw in ["none", "middle of the night", "one seventh", "angle based"]:
            return raw
        return "angle based"

    @property
    def midnight_mode(self) -> str:
        return self.config_entry.options.get(CONF_MIDNIGHT_MODE, DEFAULT_MIDNIGHT_MODE)

    @property
    def school(self) -> str:
        return self.config_entry.options.get(CONF_SCHOOL, DEFAULT_SCHOOL)

    def get_new_prayer_times(self, for_date: date) -> dict[str, Any]:
        calc = PrayerTimesCalculator(
            latitude=self.latitude,
            longitude=self.longitude,
            calculation_method=self.calc_method,
            latitudeAdjustmentMethod=self.lat_adj_method,
            midnightMode=self.midnight_mode,
            school=self.school,
            date=str(for_date),
            iso8601=True,
        )
        return cast(dict[str, Any], calc.fetch_prayer_times())

    @callback
    def async_schedule_future_update(self, midnight_dt: datetime) -> None:
        if self.event_unsub:
            self.event_unsub()
        self.event_unsub = async_track_point_in_time(
            self.hass, self.async_request_update, midnight_dt + timedelta(seconds=1)
        )

    async def async_request_update(self, _: datetime) -> None:
        await self.async_request_refresh()

    async def _async_update_data(self) -> dict[str, datetime]:
        """Resolve current location coordinates and evaluate calculations."""
        if self.location_type == METHOD_TRACKER and self.tracking_entity:
            state = self.hass.states.get(self.tracking_entity)
            if state and "latitude" in state.attributes and "longitude" in state.attributes:
                self.latitude = state.attributes["latitude"]
                self.longitude = state.attributes["longitude"]
            else:
                self.latitude = self.hass.config.latitude
                self.longitude = self.hass.config.longitude
        else:
            self.latitude = self.hass.config.latitude
            self.longitude = self.hass.config.longitude

        now = dt_util.now().replace(microsecond=0)
        today_times = self.get_new_prayer_times(now.date())
        
        today_times.pop("date", None)
        prayer_times_info: dict[str, datetime] = {}
        for prayer, time in today_times.items():
            if prayer_time := dt_util.parse_datetime(time):
                prayer_times_info[prayer] = dt_util.as_utc(prayer_time)

        self.async_schedule_future_update(prayer_times_info["Midnight"])
        return prayer_times_info
