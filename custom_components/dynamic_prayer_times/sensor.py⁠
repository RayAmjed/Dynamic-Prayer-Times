from homeassistant.components.sensor import SensorEntity, SensorDeviceClass
from homeassistant.core import HomeAssistant
from homeassistant.helpers.entity_platform import AddEntitiesCallback
from .coordinator import IslamicPrayerTimesConfigEntry, IslamicPrayerDataUpdateCoordinator
from homeassistant.helpers.update_coordinator import CoordinatorEntity

PRAYER_NAMES = ["Fajr", "Sunrise", "Dhuhr", "Asr", "Maghrib", "Isha", "Midnight", "Imsak"]

async def async_setup_entry(
    hass: HomeAssistant,
    entry: IslamicPrayerTimesConfigEntry,
    async_add_entities: AddEntitiesCallback,
) -> None:
    """Set up entry platform sensors."""
    coordinator = entry.runtime_data
    async_add_entities(
        IslamicPrayerTimeSensor(coordinator, prayer_name)
        for prayer_name in PRAYER_NAMES
    )

class IslamicPrayerTimeSensor(CoordinatorEntity[IslamicPrayerDataUpdateCoordinator], SensorEntity):
    """Representation of an Islamic prayer time sensor."""
    
    _attr_device_class = SensorDeviceClass.TIMESTAMP
    _attr_has_entity_name = True

    def __init__(self, coordinator: IslamicPrayerDataUpdateCoordinator, prayer_name: str) -> None:
        """Initialize the sensor."""
        super().__init__(coordinator)
        self.prayer_name = prayer_name
        self._attr_translation_key = prayer_name.lower()
        self._attr_unique_id = f"{coordinator.config_entry.entry_id}_{prayer_name}"

    @property
    def native_value(self):
        """Return the state of the sensor."""
        return self.coordinator.data.get(self.prayer_name)
